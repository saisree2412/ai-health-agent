# ──────────────────────────────────────────────────────────────────────
# Which client to use:
#   openai  →  OpenAI-compat HTTP (Groq, OpenRouter, Ollama, OpenAI, …) ← default
#   v2      →  llm_gatewayV2 on localhost:8100 (Session 5 zip)
#   mock    →  deterministic scripted client for offline tests
# ──────────────────────────────────────────────────────────────────────
LLM_MODE=openai

# ── If LLM_MODE=openai ────────────────────────────────────────────────
# Pick a provider. Defaults: base URL + model are inferred per provider.
LLM_PROVIDER=groq

# Provider-specific API key. The client looks for LLM_API_KEY first, then
# falls back to <PROVIDER>_API_KEY (e.g., GROQ_API_KEY).
#
# Groq          — https://console.groq.com/keys             (free, no card)
# Gemini        — https://aistudio.google.com/apikey         (free tier)
# OpenRouter    — https://openrouter.ai/keys                 (free credits + paid)
# Hugging Face  — https://huggingface.co/settings/tokens     (free tier, rate-limited)
# Mistral       — https://console.mistral.ai/api-keys/       (free tier)
# Cerebras      — https://cloud.cerebras.ai/                 (free tier)
# Together      — https://api.together.xyz/settings/api-keys (small free credits)
# Ollama        — no key; have ollama running on :11434
GROQ_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# HF_TOKEN=
# MISTRAL_API_KEY=
# CEREBRAS_API_KEY=
# TOGETHER_API_KEY=
# OPENAI_API_KEY=

# Optional overrides — only set if you want to override the provider's
# default base URL or model.
# LLM_BASE_URL=
# LLM_MODEL=

# Optional: lighter model for the verifier call only. Splitting reduces token
# burn (verifier just does JSON-schema reasoning, doesn't need the big brain).
# Examples per provider:
#   gemini:    LLM_VERIFIER_MODEL=gemini-2.5-flash-lite
#   groq:      LLM_VERIFIER_MODEL=llama-3.1-8b-instant
#   openai:    LLM_VERIFIER_MODEL=gpt-4o-mini
# LLM_VERIFIER_MODEL=

# SSL — set to "false" if you're on a corporate network that MITMs TLS
# (Zscaler, Netskope, etc.). Insecure: only enable when you trust the
# local network. Prefer LLM_CA_BUNDLE pointing at the company root cert.
# LLM_VERIFY_SSL=true
# LLM_CA_BUNDLE=/path/to/corporate-root.pem

# ── If LLM_MODE=v2 ────────────────────────────────────────────────────
LLM_GATEWAY_URL=http://localhost:8100
EXECUTOR_PROVIDER=g
VERIFIER_PROVIDER=gr

# ── External APIs ─────────────────────────────────────────────────────
# USDA FoodData Central — free, used when a food isn't in the local catalog.
# Sign up at https://fdc.nal.usda.gov/api-key-signup.html for sane rate limits.
# Without a key the agent falls back to DEMO_KEY (heavily throttled).
USDA_API_KEY=

# ── Database ──────────────────────────────────────────────────────────
DB_PATH=./health_agent.db
